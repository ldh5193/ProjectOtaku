# 네이버 클라우드 플랫폼 → AI/NAVER API → Application 등록 → Client ID
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=your_client_id_here

# Kakao Developers → 내 애플리케이션 → 앱 키 → REST API 키
# 스크래퍼(npm run scrape) + 네이버 URL 임포트 API에서 사용
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# GitHub Personal Access Token (Fine-grained, repo scope)
# 사이트 내 제보 → GitHub Issue 자동 생성에 사용 (서버 전용)
GITHUB_TOKEN=your_github_token_here
